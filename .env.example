# ================================================
# Yogev System - Environment Configuration
# ================================================
# Copy this file to .env and fill in your values
# ================================================

# ========== DATABASE ==========
# PostgreSQL password (REQUIRED - change in production!)
POSTGRES_PASSWORD=your_secure_postgres_password_here

# ========== AUTHENTICATION ==========
# JWT secret key (REQUIRED - use a strong random string in production!)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ========== EMAIL (Gmail API) ==========
# Required for password reset and notifications
# See docs for Gmail API setup: https://developers.google.com/gmail/api/quickstart
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_SENDER_EMAIL=your-sender@gmail.com

# ========== URLs ==========
# Backend internal URL (used for inter-service communication)
APP_URL=http://localhost:3001
# Frontend URL (used for CORS and email links)
FRONTEND_URL=http://localhost:3000

# ========== DATABASE SEEDING ==========
# Set to "true" on first deployment to seed initial data
# Set to "false" after initial deployment
SEED_DATABASE=false
