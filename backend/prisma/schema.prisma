generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Military Role - organizational identity
enum MilitaryRole {
  PLATOON_COMMANDER    // מפקד פלוגה
  SERGEANT_MAJOR       // סמ״פ
  OPERATIONS_SGT       // קמב״צ
  OPERATIONS_NCO       // סמב״צ
  DUTY_OFFICER         // מ״מ
  SQUAD_COMMANDER      // מפקד
  FIGHTER              // לוחם
}

// UserRole enum - used for authorization/permissions
enum UserRole {
  SOLDIER     // Basic user access
  COMMANDER   // Like soldier + receives command-level notifications
  OFFICER     // Manages their department + leave requests from department
  LOGISTICS   // Manages operational links, shifts, zones
  ADMIN       // Full system control
}

enum FormType {
  SHORT_LEAVE
  EQUIPMENT_SHORTAGE
  HOME_LEAVE
  IMPROVEMENT_SUGGESTION
  RESTAURANT_RECOMMENDATION
  SHIFT_REQUEST        // Requests during shift (food, equipment, etc.)
}

enum FormStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MessageType {
  GENERAL
  FOOD
  URGENT
  ANNOUNCEMENT
  OPERATIONAL
}

enum MessagePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MessageTargetAudience {
  ALL              // All users
  COMMANDERS_PLUS  // COMMANDER, OFFICER, LOGISTICS, ADMIN
  OFFICERS_PLUS    // OFFICER, LOGISTICS, ADMIN
  ADMIN_ONLY       // ADMIN only
}

enum ShiftType {
  GUARD
  PATROL
  KITCHEN
  CLEANING
  SPECIAL
}

enum SoldierStatusType {
  ACTIVE
  LEAVE
  SICK
  TRAINING
  OTHER
}

enum LeaveType {
  SHORT
  HOME
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  ACTIVE
  RETURNED
  OVERDUE
}

enum RecommendationCategory {
  RESTAURANT
  ACTIVITY
  SERVICE
  OTHER
}

// Department Model
model Department {
  id        String   @id @default(uuid())
  name      String   @unique // e.g., "platoon_1"
  code      String   @unique // e.g., "1"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("departments")
}

// Permission Model
model Permission {
  id          String   @id @default(uuid())
  key         String   @unique // e.g., "MANAGE_USERS"
  description String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

// Role-Permission Mapping
model RolePermission {
  id           String       @id @default(uuid())
  militaryRole MilitaryRole
  permissionId String
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now())

  @@unique([militaryRole, permissionId])
  @@map("role_permissions")
}

// User Model - Extended for new auth system
model User {
  id             String        @id @default(uuid())
  personalId     String        @unique @default("") // Primary identity - army personal number
  fullName       String
  email          String        @unique
  phone          String
  passwordHash   String

  // Military identity
  militaryRole   MilitaryRole  @default(FIGHTER)
  departmentId   String?
  department     Department?   @relation(fields: [departmentId], references: [id])

  // Legacy role field - kept for backward compatibility
  role           UserRole      @default(SOLDIER)

  // Additional fields
  armyNumber     String        @unique
  idNumber       String        @unique
  dailyJob       String?
  city           String?
  fieldOfStudy   String?
  birthDay       DateTime?

  // Registration flow flags
  isPreApproved  Boolean       @default(false) // Pre-created by admin
  isRegistered   Boolean       @default(true) // Completed registration (default true for existing users)
  isActive       Boolean       @default(true)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  formSubmissions     FormSubmission[]
  socialPosts         SocialPost[]
  recommendations     Recommendation[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  soldierStatus       SoldierStatus?
  shiftsCreated       ShiftPost[]
  operationalLinks    OperationalLink[]
  leaveRequests       LeaveRequest[]
  approvedLeaves      LeaveRequest[]    @relation("ApprovedLeaves")
  skills              SoldierSkill[]
  shiftAssignments    ShiftAssignment[]
  publishedSchedules    ShiftSchedule[]        @relation("PublishedSchedules")
  shiftOfficerDuties    ShiftSchedule[]        @relation("ShiftOfficer")
  messagesCreated       Message[]              @relation("CreatedMessages")
  messageConfirmations  MessageConfirmation[]  @relation("MessageConfirmations")

  // Reserve Service Cycle relations
  createdServiceCycles    ReserveServiceCycle[]    @relation("ServiceCycleCreator")
  serviceAttendances      ServiceAttendance[]      @relation("ServiceAttendances")
  completedChecklists     ServiceAdminChecklist[]  @relation("ChecklistCompleter")
  assignedVehicles        ServiceVehicle[]         @relation("VehicleDriver")

  // WebAuthn/Passkey credentials
  webAuthnCredentials     WebAuthnCredential[]

  @@map("users")
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
  @@map("otps")
}

// WebAuthn Credentials for Passkey/Biometric Authentication
model WebAuthnCredential {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // WebAuthn credential data
  credentialId        String    @unique // Base64URL encoded credential ID
  publicKey           String    // Base64URL encoded public key
  publicKeyAlgorithm  Int       @default(-7) // COSE algorithm identifier (-7 = ES256, -257 = RS256)
  counter             BigInt    @default(0) // Signature counter for replay protection
  transports          String[]  // Array of transport hints (usb, nfc, ble, internal, etc.)

  // Device metadata
  deviceType          String?   // "singleDevice" or "multiDevice"
  backedUp            Boolean   @default(false) // Whether credential is backed up
  deviceName          String?   // User-friendly device name

  // Timestamps
  createdAt           DateTime  @default(now())
  lastUsedAt          DateTime  @default(now())

  @@index([userId])
  @@map("webauthn_credentials")
}

// Temporary challenge storage for WebAuthn ceremonies
model WebAuthnChallenge {
  id          String   @id @default(uuid())
  challenge   String   @unique // Base64URL encoded challenge
  userId      String?  // Optional - present for registration, may be null for auth discovery
  type        String   // "registration" or "authentication"
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([challenge])
  @@index([userId])
  @@map("webauthn_challenges")
}

model Message {
  id                   String                @id @default(uuid())
  title                String
  content              String
  type                 MessageType           @default(GENERAL)
  priority             MessagePriority       @default(MEDIUM)
  targetAudience       MessageTargetAudience @default(ALL)
  requiresConfirmation Boolean               @default(false)
  isActive             Boolean               @default(true)
  createdById          String?
  createdBy            User?                 @relation("CreatedMessages", fields: [createdById], references: [id])
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  confirmations MessageConfirmation[]

  @@map("messages")
}

model MessageConfirmation {
  id          String   @id @default(uuid())
  messageId   String
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("MessageConfirmations", fields: [userId], references: [id], onDelete: Cascade)
  confirmedAt DateTime @default(now())

  @@unique([messageId, userId])
  @@map("message_confirmations")
}

model ShiftPost {
  id          String    @id @default(uuid())
  date        DateTime
  shiftType   ShiftType
  message     String?
  imageUrl    String?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("shift_posts")
}

model FormSubmission {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  type         FormType
  content      Json
  status       FormStatus @default(PENDING)
  adminComment String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("form_submissions")
}

model SocialPost {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  imageUrl  String
  caption   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("social_posts")
}

model Recommendation {
  id        String                 @id @default(uuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id])
  content   String
  category  RecommendationCategory @default(OTHER)
  isActive  Boolean                @default(true)
  createdAt DateTime               @default(now())

  @@map("recommendations")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String   // Public key
  auth      String   // Auth secret
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("push_subscriptions")
}

model SoldierStatus {
  id        String            @id @default(uuid())
  soldierId String            @unique
  soldier   User              @relation(fields: [soldierId], references: [id])
  status    SoldierStatusType @default(ACTIVE)
  note      String?
  updatedAt DateTime          @updatedAt

  @@map("soldier_statuses")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  createdAt   DateTime @default(now())

  @@map("roles")
}

model OperationalLink {
  id          String   @id @default(uuid())
  title       String
  description String?
  url         String
  isActive    Boolean  @default(true)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("operational_links")
}

model LeaveCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  icon        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  leaveRequests LeaveRequest[]

  @@map("leave_categories")
}

model LeaveRequest {
  id              String         @id @default(uuid())
  soldierId       String
  soldier         User           @relation(fields: [soldierId], references: [id])
  type            LeaveType
  categoryId      String?
  category        LeaveCategory? @relation(fields: [categoryId], references: [id])
  reason          String?
  exitTime        DateTime
  expectedReturn  DateTime
  actualReturn    DateTime?
  status          LeaveStatus    @default(PENDING)
  approvedById    String?
  approvedBy      User?          @relation("ApprovedLeaves", fields: [approvedById], references: [id])
  adminNote       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("leave_requests")
}

model Skill {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  soldiers         SoldierSkill[]
  taskRequirements TaskRequirement[]

  @@map("skills")
}

model SoldierSkill {
  id        String   @id @default(uuid())
  soldierId String
  soldier   User     @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([soldierId, skillId])
  @@map("soldier_skills")
}

model Zone {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks          Task[]
  shiftSchedules ShiftSchedule[]

  @@map("zones")
}

model Task {
  id          String   @id @default(uuid())
  zoneId      String
  zone        Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requirements     TaskRequirement[]
  shiftAssignments ShiftAssignment[]

  @@map("tasks")
}

model TaskRequirement {
  id       String @id @default(uuid())
  taskId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skillId  String
  skill    Skill  @relation(fields: [skillId], references: [id])
  quantity Int    @default(1)

  @@unique([taskId, skillId])
  @@map("task_requirements")
}

// Phase 2: Shift Management

enum ShiftAssignmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ShiftScheduleStatus {
  DRAFT
  PUBLISHED
}

model ShiftTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String
  startTime   String   // HH:MM format
  endTime     String   // HH:MM format
  color       String?  // For UI display
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments ShiftAssignment[]

  @@map("shift_templates")
}

model ShiftSchedule {
  id            String              @id @default(uuid())
  date          DateTime            @db.Date
  zoneId        String?
  zone          Zone?               @relation(fields: [zoneId], references: [id])
  status        ShiftScheduleStatus @default(DRAFT)
  publishedAt   DateTime?
  publishedById String?
  publishedBy   User?               @relation("PublishedSchedules", fields: [publishedById], references: [id])

  // Shift Officer for the day
  shiftOfficerId String?
  shiftOfficer   User?               @relation("ShiftOfficer", fields: [shiftOfficerId], references: [id])

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  assignments ShiftAssignment[]

  @@unique([date, zoneId])
  @@map("shift_schedules")
}

model ShiftAssignment {
  id              String                @id @default(uuid())
  scheduleId      String?
  schedule        ShiftSchedule?        @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  date            DateTime              @db.Date
  shiftTemplateId String
  shiftTemplate   ShiftTemplate         @relation(fields: [shiftTemplateId], references: [id])
  taskId          String
  task            Task                  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  soldierId       String
  soldier         User                  @relation(fields: [soldierId], references: [id], onDelete: Cascade)
  status          ShiftAssignmentStatus @default(PENDING)
  notes           String?

  // Active Shift Management fields
  arrivedAt       DateTime?             // When soldier confirmed arrival
  hasVehicle      Boolean               @default(false)  // Vehicle availability
  hasPhone        Boolean               @default(false)  // Phone availability
  hasBattery      Boolean               @default(false)  // Battery/radio availability
  missingItems    String?                                // Free text for missing items

  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([date, shiftTemplateId, taskId, soldierId])
  @@map("shift_assignments")
}

// ============================================================
// RESERVE SERVICE CYCLE - סבב מילואים
// ============================================================

enum ReserveServiceCycleStatus {
  PLANNED   // מתוכנן
  ACTIVE    // פעיל
  COMPLETED // הושלם
  CANCELLED // בוטל
}

enum ServiceAttendanceStatus {
  PENDING     // ממתין לעדכון
  ARRIVED     // הגיע
  NOT_COMING  // לא מגיע
  LATE        // איחור
  LEFT_EARLY  // יצא מוקדם
}

enum ServiceChecklistCategory {
  STAFF      // סגל
  VEHICLES   // רכבים
  LOGISTICS  // לוגיסטיקה
  HOTEL      // מלון
  WEAPONS    // נשקים
  GENERAL    // כללי
}

// סבב מילואים / גיוס נוכחי
model ReserveServiceCycle {
  id          String                     @id @default(uuid())
  name        String                     // שם הסבב
  description String?                    // תיאור
  startDate   DateTime                   @db.Date // תאריך התחלה
  endDate     DateTime?                  @db.Date // תאריך סיום
  location    String?                    // מיקום
  status      ReserveServiceCycleStatus  @default(PLANNED)

  createdById String
  createdBy   User                       @relation("ServiceCycleCreator", fields: [createdById], references: [id])

  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  // Relations
  attendances        ServiceAttendance[]
  adminChecklists    ServiceAdminChecklist[]
  vehicles           ServiceVehicle[]

  @@map("reserve_service_cycles")
}

// נוכחות / הצטרפות חייל לסבב
model ServiceAttendance {
  id                  String                   @id @default(uuid())
  serviceCycleId      String
  serviceCycle        ReserveServiceCycle      @relation(fields: [serviceCycleId], references: [id], onDelete: Cascade)
  userId              String
  user                User                     @relation("ServiceAttendances", fields: [userId], references: [id], onDelete: Cascade)

  attendanceStatus    ServiceAttendanceStatus  @default(PENDING)
  cannotAttendReason  String?                  // סיבת אי-הגעה

  checkInAt           DateTime?                // זמן הגעה בפועל
  checkOutAt          DateTime?                // זמן יציאה

  onboardGunNumber    String?                  // מספר נשק
  hotelRoomNumber     String?                  // מספר חדר
  notes               String?                  // הערות

  totalActiveDays     Int                      @default(0) // ימי פעילות מצטברים

  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([serviceCycleId, userId])
  @@map("service_attendances")
}

// צ'קליסט סגל / לוגיסטיקה
model ServiceAdminChecklist {
  id              String                    @id @default(uuid())
  serviceCycleId  String
  serviceCycle    ReserveServiceCycle       @relation(fields: [serviceCycleId], references: [id], onDelete: Cascade)

  category        ServiceChecklistCategory  @default(GENERAL)
  title           String                    // כותרת
  description     String?                   // תיאור

  isCompleted     Boolean                   @default(false)
  completedById   String?
  completedBy     User?                     @relation("ChecklistCompleter", fields: [completedById], references: [id])
  completedAt     DateTime?

  notes           String?                   // הערות
  sortOrder       Int                       @default(0)

  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@map("service_admin_checklists")
}

// רכבים בסבב (Phase 2 - basic structure)
model ServiceVehicle {
  id              String               @id @default(uuid())
  serviceCycleId  String
  serviceCycle    ReserveServiceCycle  @relation(fields: [serviceCycleId], references: [id], onDelete: Cascade)

  vehicleNumber   String               // מספר רכב
  vehicleType     String?              // סוג רכב
  driverUserId    String?
  driver          User?                @relation("VehicleDriver", fields: [driverUserId], references: [id])

  notes           String?
  isActive        Boolean              @default(true)

  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@map("service_vehicles")
}
